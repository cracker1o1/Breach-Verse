{
  "name": "client-side-security-platform",
  "version": "1.0.0",
  "description": "BREACH-VERSE - Advanced Client-Side Security Intelligence Engine",
  "main": "packages/core/src/index.ts",
  "scripts": {
    "start": "node --dns-result-order=ipv4first --max-old-space-size=2560 node_modules/.bin/ts-node packages/core/src/index.ts",
    "batch": "node --dns-result-order=ipv4first --max-old-space-size=2560 node_modules/.bin/ts-node packages/core/src/batch_analyzer.ts",
    "clear": "rm -f packages/database/prisma/dev.db security_report.* openapi_spec.json encrypted.bin && rm -rf reconstructed_sources && npx prisma db push --schema=./packages/database/prisma/schema.prisma",
    "help": "node --dns-result-order=ipv4first --max-old-space-size=2560 node_modules/.bin/ts-node packages/core/src/index.ts --help"
  },
  "keywords": [
    "security",
    "ast",
    "reverse-engineering",
    "taint-analysis"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.61.1",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "@types/node": "^20.11.24",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
